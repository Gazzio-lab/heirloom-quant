{
  "name": "heirloom-quant",
  "version": "2024.1.0",
  "description": "Cross-platform financial calculator suite (Investment, Estate, Tax, Retirement, 199A, etc.) — Heirloom Quant.",
  "author": {
    "name": "Heirloom Quant",
    "email": "support@example.com"
  },
  "license": "MIT",
  "main": "dist/app/main.js",
  "scripts": {
    "clean": "rimraf dist out release",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "dev": "concurrently --kill-others \"vite build --watch\" \"wait-on dist/renderer/index.html && electron . --enable-logging\"",
    "start": "npm run build && electron .",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder -mw"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.14",
    "rimraf": "^5.0.5",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.heirloomquant.desktop",
    "productName": "Heirloom Quant",
    "copyright": "Copyright © 2024 Heirloom Quant",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraFiles": [],
    "extraResources": [
      {
        "from": "src/data/static",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Heirloom Quant ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Heirloom Quant"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office;Finance"
    }
  }
}
