{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noImplicitAny": true,
    "baseUrl": "./src",
    "paths": {
      "@core/*":        ["core/*"],
      "@calculators/*": ["calculators/*"],
      "@data/*":        ["data/*"],
      "@app/*":         ["app/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules", "dist", "release",
    "tests",
    "src/renderer/**",
    "src/app/renderer/**",
    "vite.config.ts"
  ]
}
